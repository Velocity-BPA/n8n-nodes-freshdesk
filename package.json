{
  "name": "n8n-nodes-freshdesk",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Freshdesk helpdesk platform providing 10 resources and 60+ operations for ticket management, customer support, and knowledge base automation.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-freshdesk.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-freshdesk#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-freshdesk/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "freshdesk",
    "helpdesk",
    "customer-support",
    "ticketing",
    "freshworks",
    "automation",
    "workflow",
    "support",
    "knowledge-base",
    "crm"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FreshdeskApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Freshdesk/Freshdesk.node.js",
      "dist/nodes/Freshdesk/FreshdeskTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "cp -r nodes/Freshdesk/*.svg dist/nodes/Freshdesk/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
